# ── Groq (LLM for all 9 agents) ──
# Get a free key at https://console.groq.com
GROQ_API_KEY=your-groq-key-here
# Optional: comma-separated list of multiple keys for rotation:
# GROQ_API_KEYS=key1,key2,key3
# Optional: override the default model (llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Band platform URLs (do not change) ──
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ── Band — Streamlit UI (Human API: posts the kickoff + polls replies) ──
# Your personal Band API key (from app.band.ai). Used by app.py only.
BAND_HUMAN_API_KEY=your-band-human-api-key
# The chat/room id of your LoanShark room (all 9 agents are participants).
BAND_CHAT_ID=your-chat-id

# ── Band — agent @mention handles ──
# Your Band username; agent handles default to @<user>/<AgentName>.
BAND_USER_HANDLE=your-band-username
# The human loan officer handle the Communication agent notifies (optional).
# BAND_OPERATOR_HANDLE=@your-username
# Per-agent handle overrides — only if your handles differ from the default:
# BAND_HANDLE_INTAKE=@your-username/IntakeAgent
# BAND_HANDLE_DOCUMENT=@your-username/DocumentAgent
# BAND_HANDLE_CREDIT=@your-username/CreditAgent
# BAND_HANDLE_FRAUD=@your-username/FraudAgent
# BAND_HANDLE_RISK=@your-username/RiskAgent
# BAND_HANDLE_COMPLIANCE=@your-username/ComplianceAgent
# BAND_HANDLE_DECISION=@your-username/DecisionAgent
# BAND_HANDLE_PRICING=@your-username/PricingAgent
# BAND_HANDLE_COMMUNICATION=@your-username/CommunicationAgent

# ── App ──
APP_ENV=development
