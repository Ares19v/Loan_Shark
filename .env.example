# Band Platform URLs (do not change these)
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Groq API key — get free at console.groq.com
GROQ_API_KEY=your-groq-key-here

# Band Room ID — paste from band.ai room URL after creating the room
BAND_ROOM_ID=your-room-id-here

# App Config
APP_ENV=development
